{
  "manifest_version": 3,
  "name": "WAD",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
  "service_worker": "assets/background.js",
  "type": "module"
  },
  "permissions": [
    "sidePanel",
    "scripting",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}